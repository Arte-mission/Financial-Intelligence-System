# ── Required ────────────────────────────────────────────────────────────────
# Gemini API key for the AI interpretation layer (stock signal analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ─────────────────────────────────────────────────────────────────
# NewsData.io API key. Used as a supplementary fallback when OnlineKhabar
# returns fewer than 4 relevant articles. Leave unset to run in
# OnlineKhabar-only mode (recommended for deployment without a paid plan).
# NEWSDATA_API_KEY=your_newsdata_key_here

# ── Database (optional, default SQLite path is used if not set) ──────────────
# DATABASE_URL=sqlite:///./market.db
